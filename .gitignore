src/.vscode/*
src/!.vscode/settings.json
src/!.vscode/tasks.json
src/!.vscode/launch.json
src/!.vscode/extensions.json
src/!.vscode/*.code-snippets

# Local History for Visual Studio Code
.history/

# Built Visual Studio Code Extensions
*.vsix

src/.gdb_history

*.exe
*.dll

# Runtime artifacts
src/.Zathura.zlog
src/config.zlyt
src/imgui.ini

# Build outputs
src/Zathura
src/build/
src/cmake-build-debug/
src/cmake-build-release/
src/*.o
src/CMakeFiles/
src/*.cmake

# IDE files (already partially covered but .idea is tracked)
.idea/

# Vendor prebuilt binaries
vendor/**/*.dll
vendor/**/*.dylib
vendor/**/*.so
vendor/**/*.o

# Prebuilt binaries shipped with source tree
src/app/dialogs/tinyfiledialogs/**/*.dll
src/app/dialogs/tinyfiledialogs/**/*.dylib
src/app/dialogs/tinyfiledialogs/**/*.so
